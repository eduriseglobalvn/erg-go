# Copy this file to .env.production on the VPS.
# Never commit the real .env.production file.

ERG_IMAGE=erg-go:latest
ERG_VERSION=local
ERG_COMMIT=local
ERG_BUILD_DATE=local
ERG_HTTP_PORT=8080

POSTGRES_USER=erg
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=erg

APP__HOST=0.0.0.0
APP__PORT=8080
APP__ENV=production
APP__READ_TIMEOUT=15s
APP__WRITE_TIMEOUT=15s
APP__IDLE_TIMEOUT=60s
APP__SHUTDOWN_TIME=30s

HTTP__HOST=0.0.0.0
HTTP__PORT=8080
HTTP__TRUSTED_PROXY_CIDRS=
HTTP__RATE_LIMIT__ENABLED=true
HTTP__RATE_LIMIT__REQUESTS_PER_MINUTE=100
HTTP__RATE_LIMIT__BURST=20
HTTP__CORS__ALLOWED_ORIGINS=https://lms.erg.edu.vn,https://hoclieu.erg.edu.vn
HTTP__CORS__ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
HTTP__CORS__ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-Request-ID,X-CSRF-Token
HTTP__CORS__EXPOSED_HEADERS=X-Request-ID
HTTP__CORS__ALLOW_CREDENTIALS=true
HTTP__CORS__MAX_AGE=86400

MONGO_INITDB_ROOT_USERNAME=erg
MONGO_INITDB_ROOT_PASSWORD=replace-with-mongo-root-password
MONGO_INITDB_DATABASE=erg
MONGODB__URI=mongodb://erg:replace-with-mongo-root-password@mongodb:27017/erg?authSource=admin
MONGODB__DATABASE=erg
MONGODB__AUTH_SOURCE=admin
MONGODB__MAX_POOL_SIZE=100
MONGODB__MIN_POOL_SIZE=5
MONGODB__SERVER_SELECTION_TIMEOUT=10s
MONGODB__CONNECT_TIMEOUT=10s
MONGODB__READ_PREFERENCE=primary

DB__HOST=postgres
DB__PORT=5432
DB__USER=erg
SECRET_DB__PASSWORD=replace-with-postgres-password
DB__NAME=erg
DB__SSL_MODE=disable
DB__MAX_OPEN_CONNS=25
DB__MAX_IDLE_CONNS=5
DB__CONN_MAX_LIFETIME=30m
DB__CONN_MAX_IDLE_TIME=5m
DB__AUTO_MIGRATE=false
DB__RUN_BACKFILLS=false
DB__MIGRATION_TIMEOUT=2m

REDIS_PASSWORD=replace-with-redis-password
REDIS__HOST=redis
REDIS__PORT=6379
REDIS__USERNAME=
SECRET_REDIS__PASSWORD=replace-with-redis-password
REDIS__TLS=false
REDIS__DB=0
REDIS__DIAL_TIMEOUT=5s
REDIS__READ_TIMEOUT=3s
REDIS__WRITE_TIMEOUT=3s
REDIS__POOL_SIZE=10
REDIS__MIN_IDLE_CONNS=2
REDIS__MAX_RETRIES=3

QUEUE__REDIS_HOST=redis
QUEUE__REDIS_PORT=6379
QUEUE__REDIS_USERNAME=
SECRET_QUEUE__REDIS_PASSWORD=replace-with-redis-password
QUEUE__REDIS_DB=0
QUEUE__REDIS_TLS=false
QUEUE__CONCURRENCY=10
QUEUE__RETRY_DELAY=10s
QUEUE__MAX_RETRY=3
QUEUE__QUEUE_NAME=default
QUEUE__DLQ_QUEUE_NAME=erg-dlq
QUEUE__RETRY_BACKOFF=true
QUEUE__IS_SERVER=true

SECRET_AUTH__JWT_SECRET=replace-with-jwt-access-secret-minimum-32-chars
SECRET_AUTH__JWT_REFRESH_SECRET=replace-with-jwt-refresh-secret-minimum-32-chars
AUTH__JWT_ISSUER=erg-server
AUTH__JWT_ALGORITHMS=HS256
AUTH__ACCESS_TOKEN_TTL=15m
AUTH__REFRESH_TOKEN_TTL=168h
AUTH__BEARER_PREFIX=Bearer
AUTH__COOKIE__ENABLED=true
AUTH__COOKIE__DOMAIN=.erg.edu.vn
AUTH__COOKIE__SECURE=true
AUTH__COOKIE__SAME_SITE=lax
AUTH__COOKIE__ACCESS_TOKEN_NAME=erg_access_token
AUTH__COOKIE__REFRESH_TOKEN_NAME=erg_refresh_token
AUTH__MAX_FAILED_LOGIN=5
AUTH__FAILED_LOGIN_WINDOW=15m
AUTH__BLOCK_DURATION=15m
AUTH__GEO_BLOCK_ENABLED=true
AUTH__BLOCK_UNKNOWN_GEO=false
AUTH__ALLOWED_CONTINENTS=AS
AUTH__ADMIN_EMAIL=admin@erg.edu.vn
SECRET_AUTH__ADMIN_PASSWORD=replace-with-admin-password

LIFECYCLE__AUTH_BOOTSTRAP_ADMIN_ON_STARTUP=false
LIFECYCLE__PROFILE_BACKFILL_ON_STARTUP=false
LIFECYCLE__OPERATION_SEED_ON_STARTUP=false
LIFECYCLE__TRENDING_REFRESH_ON_STARTUP=false
LIFECYCLE__LMS_SEED_ON_STARTUP=false

TENANT__ENABLED=true
TENANT__ISOLATION=field
TENANT__DEFAULT_ID=default

LOGGING__LEVEL=info
LOGGING__FORMAT=json
LOGGING__TIME_FORMAT=RFC3339

TELEMETRY__ENABLED=false
TELEMETRY__SERVICE_NAME=erg-server
TELEMETRY__SERVICE_VERSION=0.1.0
TELEMETRY__ENVIRONMENT=production

# Optional external services. Leave blank to disable related upload/email/AI features.
SMTP__HOST=
SMTP__PORT=587
SMTP__USERNAME=
SECRET_SMTP__PASSWORD=
SMTP__FROM=noreply@erg.edu.vn
SMTP__TLS=true

R2__BUCKET_NAME=
R2__ENDPOINT=
SECRET_R2__ACCESS_KEY_ID=
SECRET_R2__SECRET_KEY=
R2__PUBLIC_DOMAIN=
R2__REGION=auto

AI__PROVIDER=groq
SECRET_AI__API_KEY_ENCRYPTION_SECRET=replace-with-ai-key-encryption-secret-32chars
SECRET_AI__GROQ_API_KEY=
AI__GROQ_MODEL=openai/gpt-oss-120b
AI__GROQ_BASE_URL=https://api.groq.com/openai/v1
AI__GROQ_TIMEOUT=30s
AI__GROQ_MAX_COMPLETION_TOKENS=4096
AI__GROQ_TEMPERATURE=1
AI__GROQ_REASONING_EFFORT=medium
SECRET_AI__GEMINI_API_KEY=
AI__GEMINI_MODEL=gemini-2.0-flash
AI__GEMINI_TIMEOUT=10s
AI__CACHE_TTL=24h
AI__BATCH_SIZE=10
