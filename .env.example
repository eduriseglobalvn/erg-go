# erg-server — Environment Variables Template
# Copy to .env and fill in the values.
# All values here are safe defaults for local development.
# Override any value with: SECRET_<UPPER_KEY>=<value>
#
# Secret injection: prefix secret values with SECRET_ to bypass config.yaml defaults.
# Example: SECRET_auth.jwt_secret=my-super-secret → sets auth.jwt_secret
#
# ── APP ─────────────────────────────────────────────────────────────────────────
APP__HOST=0.0.0.0
APP__PORT=8080
APP__ENV=development
APP__READ_TIMEOUT=15s
APP__WRITE_TIMEOUT=15s
APP__IDLE_TIMEOUT=60s
APP__SHUTDOWN_TIME=30s

# ── DATABASE (PostgreSQL — for modules like recruitment) ─────────────────────────
# NOTE: Primary data uses MongoDB. PostgreSQL is used by specific modules (e.g. recruitment).
DB__HOST=127.0.0.1
DB__PORT=5432
DB__USER=postgres
DB__PASSWORD=replace-with-local-postgres-password
DB__NAME=erg
DB__MAX_OPEN_CONNS=25
DB__MAX_IDLE_CONNS=5
DB__CONN_MAX_LIFETIME=30m
DB__CONN_MAX_IDLE_TIME=5m
DB__AUTO_MIGRATE=false
DB__RUN_BACKFILLS=false
DB__MIGRATION_TIMEOUT=2m

# ── MONGODB ────────────────────────────────────────────────────────────────────
# Primary database for all modules (users, posts, pages, etc.)
MONGODB__URI=mongodb://localhost:27017
MONGODB__DATABASE=erg
MONGODB__AUTH_SOURCE=admin
MONGODB__MAX_POOL_SIZE=100
MONGODB__MIN_POOL_SIZE=10
MONGODB__SERVER_SELECTION_TIMEOUT=10s
MONGODB__CONNECT_TIMEOUT=10s
MONGODB__READ_PREFERENCE=secondaryPreferred

# ── REDIS ──────────────────────────────────────────────────────────────────────
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__USERNAME=
# REDIS__PASSWORD=                        # Set if Redis requires authentication
REDIS__TLS=false
REDIS__DB=0
REDIS__DIAL_TIMEOUT=5s
REDIS__READ_TIMEOUT=3s
REDIS__WRITE_TIMEOUT=3s
REDIS__POOL_SIZE=10
REDIS__MIN_IDLE_CONNS=5
REDIS__MAX_RETRIES=3

# ── AUTH / JWT ─────────────────────────────────────────────────────────────────
# JWT secrets — MUST match erg-backend .env for cross-service auth compatibility.
# IMPORTANT: Generate strong random strings for production. Minimum 32 chars.
SECRET_AUTH__JWT_SECRET=replace-with-strong-random-secret-min-32-chars
SECRET_AUTH__JWT_REFRESH_SECRET=replace-with-different-strong-random-secret-min-32-chars
AUTH__JWT_ISSUER=erg-backend
AUTH__JWT_ALGORITHMS=HS256
AUTH__BEARER_PREFIX=Bearer
AUTH__SKIP_PATHS=/healthz,/ready,/metrics,/swagger
AUTH__MAX_FAILED_LOGIN=5
AUTH__FAILED_LOGIN_WINDOW=15m
AUTH__BLOCK_DURATION=15m
AUTH__GEO_BLOCK_ENABLED=true
AUTH__BLOCK_UNKNOWN_GEO=false
AUTH__ALLOWED_CONTINENTS=AS
AUTH__COOKIE__ENABLED=true
# Local: leave empty for host-only cookies. Production: use .erg.edu.vn
AUTH__COOKIE__DOMAIN=
AUTH__COOKIE__SECURE=false
AUTH__COOKIE__SAME_SITE=lax
AUTH__COOKIE__ACCESS_TOKEN_NAME=erg_access_token
AUTH__COOKIE__REFRESH_TOKEN_NAME=erg_refresh_token
# Super-admin bootstrap. If the account already exists, startup repairs its
# status/roles/profile metadata. Password is only required when creating it.
AUTH__ADMIN_EMAIL=admin@erg.edu.vn
SECRET_AUTH__ADMIN_PASSWORD=replace-with-strong-admin-password

# ── R2 CLOUDFLARE STORAGE ──────────────────────────────────────────────────────
# Used for file uploads (posts, documents, user avatars).
# Get credentials from Cloudflare Dashboard → R2 → Manage API Tokens.
SECRET_R2__ACCESS_KEY_ID=
SECRET_R2__SECRET_KEY=
R2__BUCKET_NAME=erg-media
R2__ENDPOINT=https://abc123.r2.cloudflarestorage.com
R2__PUBLIC_DOMAIN=https://cdn.erg.edu.vn
R2__REGION=auto

# ── SMTP (Email) ──────────────────────────────────────────────────────────────
# Used for transactional emails (PIN verification, password reset, etc.).
SMTP__HOST=smtp.gmail.com
SMTP__PORT=587
SMTP__USERNAME=your-email@gmail.com
SECRET_SMTP__PASSWORD=
SMTP__FROM=noreply@erg.edu.vn
SMTP__TLS=true

# ── QUEUE (Asynq / Redis-backed job queue) ─────────────────────────────────────
QUEUE__REDIS_HOST=localhost
QUEUE__REDIS_PORT=6379
# QUEUE__REDIS_PASSWORD=                  # Set if Redis requires auth
QUEUE__REDIS_USERNAME=
QUEUE__REDIS_DB=0
QUEUE__REDIS_TLS=false
QUEUE__CONCURRENCY=10
QUEUE__RETRY_DELAY=10s
QUEUE__MAX_RETRY=3
QUEUE__QUEUE_NAME=default
QUEUE__DLQ_QUEUE_NAME=erg-dlq
QUEUE__RETRY_BACKOFF=true
QUEUE__IS_SERVER=true

# ── HTTP SERVER ─────────────────────────────────────────────────────────────────
HTTP__HOST=0.0.0.0
HTTP__PORT=8080
HTTP__READ_TIMEOUT=15s
HTTP__WRITE_TIMEOUT=15s
HTTP__IDLE_TIMEOUT=60s
HTTP__SHUTDOWN_TIMEOUT=30s
# Comma-separated CIDR/IP allowlist for proxies allowed to set X-Forwarded-For/X-Real-IP.
HTTP__TRUSTED_PROXY_CIDRS=
HTTP__RATE_LIMIT__ENABLED=true
HTTP__RATE_LIMIT__REQUESTS_PER_MINUTE=100
HTTP__RATE_LIMIT__BURST=20
# CORS origins (comma-separated; use * for wildcard in dev only)
HTTP__CORS__ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3003
HTTP__CORS__ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
HTTP__CORS__ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-Request-ID
HTTP__CORS__EXPOSED_HEADERS=X-Request-ID
HTTP__CORS__ALLOW_CREDENTIALS=true
HTTP__CORS__MAX_AGE=86400

# ── AI (Gemini) ─────────────────────────────────────────────────────────────────
AI__PROVIDER=groq
SECRET_AI__GROQ_API_KEY=
AI__GROQ_MODEL=openai/gpt-oss-120b
AI__GROQ_BASE_URL=https://api.groq.com/openai/v1
AI__GROQ_TIMEOUT=30s
AI__GROQ_MAX_COMPLETION_TOKENS=4096
AI__GROQ_TEMPERATURE=1
AI__GROQ_REASONING_EFFORT=medium
SECRET_AI__GEMINI_API_KEY=
AI__GEMINI_MODEL=gemini-2.0-flash
AI__GEMINI_TIMEOUT=10s
AI__CACHE_TTL=24h
AI__BATCH_SIZE=10

# ── SCRAPER ────────────────────────────────────────────────────────────────────
SCRAPER__MIN_DELAY=3s
SCRAPER__MAX_DELAY=10s
SCRAPER__TIMEOUT=30s
SCRAPER__MAX_RESPONSE_SIZE=10485760
SCRAPER__RESPECT_ROBOTS_TXT=true
SCRAPER__MAX_RETRIES=3

# ── TRENDING ───────────────────────────────────────────────────────────────────
TRENDING__REFRESH_CRON=*/30 * * * *
TRENDING__CACHE_TTL=25m
TRENDING__FEED_LIMIT=100
TRENDING__TOPICS_LIMIT=20
TRENDING__NEWS_LIMIT=20
TRENDING__MIN_HOT_SCORE=75

# ── TELEMETRY (OpenTelemetry + Prometheus) ────────────────────────────────────
TELEMETRY__ENABLED=true
TELEMETRY__SERVICE_NAME=erg-server
TELEMETRY__SERVICE_VERSION=0.1.0
TELEMETRY__ENVIRONMENT=development
# TELEMETRY__JAEGER_ENDPOINT=http://localhost:14268/api/traces

# ── LOGGING ─────────────────────────────────────────────────────────────────────
LOGGING__LEVEL=debug
LOGGING__FORMAT=console
LOGGING__TIME_FORMAT=RFC3339

# ── DISCORD BOT ─────────────────────────────────────────────────────────────────
# Discord bot for bot commands and webhook integrations.
SECRET_DISCORD__TOKEN=
SECRET_DISCORD__PUBLIC_KEY=
SECRET_DISCORD__WEBHOOK_SECRET=
DISCORD__WEBHOOK_URL=
DISCORD__GUILD_ID=

# ── TELEGRAM BOT ───────────────────────────────────────────────────────────────
SECRET_TELEGRAM__BOT_TOKEN=
SECRET_TELEGRAM__WEBHOOK_SECRET=
TELEGRAM__WEBHOOK_URL=

# ── WHATSAPP BUSINESS API ───────────────────────────────────────────────────────
WHATSAPP__PHONE_ID=
SECRET_WHATSAPP__ACCESS_TOKEN=
WHATSAPP__VERIFY_TOKEN=

# ── BOT ─────────────────────────────────────────────────────────────────────────
BOT__COMMAND_PREFIX=/
# BOT__ADMIN_IDS=                        # Comma-separated Discord user IDs
BOT__MAX_CONVERSATIONS=10000
BOT__WIZARD_TTL_MINUTES=5
BOT__RATE_LIMIT_PER_USER=20
BOT__ENABLE_LINK_COMMAND=true
# BOT__NOTIFICATION_CHANNEL=            # Discord channel for system notifications

# ── MODULES (Phase 4 — selective module loading) ────────────────────────────────
# Empty = all modules loaded (default). Set to specific module names to load only those.
# Valid values: bot, crawler, notification, trending
# MODULES__ENABLED=bot,crawler,notification,trending
