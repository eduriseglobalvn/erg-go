# Local-only override example.
# Copy to config/application.local.yaml and fill values on your machine.
# The real application.local.yaml file is gitignored.

database:
  password: replace-with-local-postgres-password

auth:
  jwt_secret: replace-with-local-jwt-secret-min-32-chars
  google_client_id: replace-with-google-oauth-web-client-id.apps.googleusercontent.com

smtp:
  host: smtp.example.com
  username: noreply@example.com
  password: replace-with-local-smtp-password
  from: "No Reply <noreply@example.com>"

r2:
  endpoint: https://example.r2.cloudflarestorage.com
  access_key_id: replace-with-local-r2-access-key-id
  secret_key: replace-with-local-r2-secret-key
  bucket_name: erg-dev
  public_domain: https://media.example.com

ai:
  provider: groq
  groq_api_key: replace-with-local-groq-api-key
  groq_model: openai/gpt-oss-120b
  huggingface_image_api_key: replace-with-local-huggingface-token
  huggingface_image_provider: fal-ai
  huggingface_image_model: black-forest-labs/FLUX.1-Krea-dev
