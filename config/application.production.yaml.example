# Example production profile. Copy to application.production.yaml only if your
# deployment model stores non-secret production config in this repo/workspace.
# Keep real secrets in the platform secret manager or SECRET_* environment vars.

app:
  env: production

http:
  cors:
    allowed_origins:
      - https://erg.edu.vn
      - https://app.erg.edu.vn
    allow_credentials: true

logging:
  level: info
  format: json

telemetry:
  enabled: true
  environment: production

auth:
  # Production can intentionally raise password hash cost if p95 latency budget
  # and CPU capacity allow it. The shared default favors local/dev feedback speed.
  argon2_memory: 65536
  argon2_iterations: 3

mongodb:
  read_preference: primaryPreferred
  max_pool_size: 300
  min_pool_size: 30

redis:
  tls: true
  pool_size: 100
  min_idle_conns: 20

queue:
  redis_tls: true
  concurrency: 50

ai:
  provider: groq
  groq_model: openai/gpt-oss-120b
  groq_base_url: https://api.groq.com/openai/v1
  groq_timeout: 30s
  groq_max_completion_tokens: 4096
  groq_temperature: 1
  groq_reasoning_effort: medium
